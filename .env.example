# Copy this file to .env and fill in the paths for your machine.
# .env is gitignored and must never be committed.
# Each variable points to the top-level directory of the corresponding dataset.

DATASET_CUBEPP_ROOT=/path/to/Cube++
DATASET_GEHLER_ROOT=/path/to/ShiGehler
DATASET_NUS8_ROOT=/path/to/NUS8
DATASET_LSMI_ROOT=/path/to/LSMI/data
DATASET_MINIATURE_ROOT=/path/to/Miniature
DATASET_REALLIFE_ROOT=/path/to/Reallife
